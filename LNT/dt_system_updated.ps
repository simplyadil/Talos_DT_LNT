% BCG_BEGIN_SECTION_1
/vertex_radius { 12.000000 } def
/arrow_shape_1 { 7 } def
/arrow_shape_2 { 9 } def
/arrow_shape_3 { 3 } def
/Times-Roman findfont 10.000000 scalefont setfont
/text_y_shift { -3 } def
% BCG_END_SECTION_1
