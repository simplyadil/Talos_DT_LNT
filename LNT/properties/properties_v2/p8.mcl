macro GOOD_TERMINAL () =
  ("STOP_SENT" or "BASE_STOPPED" or "JOINT_STOPPED" or
   "DEVIATION_HANDLED" or "STREAM_DONE")
end_macro

(* P8: Every execution path eventually reaches a good terminal (Liveness - inevitability) *)
[ true* ]
  mu X . ( < GOOD_TERMINAL > true or ( [ not GOOD_TERMINAL ] X and < true > true ) )
